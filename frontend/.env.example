# Leave empty for local dev — Vite proxy forwards /api/* to Express on port 3000
# Set to full backend URL when deploying: VITE_API_URL=https://api.finlearn.stei.cloud
VITE_API_URL=

# Fallback ExchangeRate API (used client-side when backend is unreachable)
VITE_EXCHANGE_API_URL=https://api.coingecko.com/api/v3/simple/price?ids=usd-coin,bitcoin,ethereum&vs_currencies=usd,idr,sgd,myr,jpy
